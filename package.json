{
  "name": "mixer",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @mixer/contracts build && concurrently -n contracts,api,ai,mobile -c gray,blue,magenta,green \"pnpm dev:contracts\" \"pnpm dev:api\" \"pnpm dev:ai\" \"pnpm dev:mobile\"",
    "dev:services": "pnpm --filter @mixer/contracts build && concurrently -n contracts,api,ai -c gray,blue,magenta \"pnpm dev:contracts\" \"pnpm dev:api\" \"pnpm dev:ai\"",
    "dev:contracts": "pnpm --filter @mixer/contracts dev",
    "dev:api": "pnpm --filter @mixer/api dev",
    "dev:ai": "pnpm --filter @mixer/ai dev",
    "dev:mobile": "pnpm --filter @mixer/mobile start",
    "build": "pnpm --filter @mixer/contracts build && pnpm -r --filter \"./apps/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "expo-localization": "^56.0.6",
    "fastify": "^5.8.5",
    "pnpm": "^10.33.4"
  }
}
